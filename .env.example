# .env.example — Template for project secrets
#
# DO NOT put real values here. This file is committed to git.
# Real secrets are stored in your OS keychain via secret_loader.py.
#
# To set up secrets:
#   bash scripts/setup_security.sh
#   -- or --
#   python3 security/secret_loader.py --setup
#
# To add a secret manually:
#   python3 security/secret_loader.py --set MY_KEY my_value

# ── Example secrets (replace with your project's actual keys) ──────────────

# API Keys
MY_API_KEY=

# Database
DATABASE_URL=

# External services
WEBHOOK_URL=

# Add your project-specific secrets below:

