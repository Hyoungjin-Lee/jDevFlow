# .env.example — Secret KEY NAMES (no values)
#
# This file is committed to git. It holds ONLY the list of secret key names
# the project expects. It must NEVER contain real values.
#
# Real secrets live in the OS keychain (macOS Keychain / Windows Credential
# Manager), accessed via security/secret_loader.py.
#
# To set up real secrets (interactive):
#   bash scripts/setup_security.sh
#   -- or --
#   python3 security/secret_loader.py --setup
#
# To add a single secret manually:
#   python3 security/secret_loader.py --set MY_KEY my_value
#
# .env (no "example" suffix) is an OPTIONAL local scratch file. It is
# .gitignore'd. Never put production secrets there either.

# ── Example secrets (replace with your project's actual keys) ──────────────

# API Keys
MY_API_KEY=

# Database
DATABASE_URL=

# External services
WEBHOOK_URL=

# Add your project-specific secrets below:

